<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:m="using:SourceGit.Models"
             xmlns:vm="using:SourceGit.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SourceGit.Views.RepositoryToolbar"
             x:DataType="vm:Repository">
  <Grid Height="48" ColumnDefinitions="*,Auto,0,*">
    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0,0,0">
      <Button Classes="icon_button" Width="52" Click="OpenWithExternalTools" ToolTip.Tip="{DynamicResource Text.Repository.OpenWithExternalTools}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.OpenWith}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Repository.OpenWithExternalTools}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="52" Click="OpenGitLogs" ToolTip.Tip="{DynamicResource Text.Repository.ViewLogs}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Logs}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Repository.ViewLogs}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="52" Click="OpenStatistics" ToolTip.Tip="{DynamicResource Text.Repository.Statistics}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Statistics}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Repository.Statistics}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="60" Click="OpenConfigure" ToolTip.Tip="{DynamicResource Text.Repository.Configure}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Settings}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Repository.Configure}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <StackPanel Grid.Column="1" Orientation="Horizontal">
      <Button Classes="icon_button" Width="48" Tapped="Fetch">
        <ToolTip.Tip>
          <StackPanel Orientation="Vertical">
            <TextBlock Text="{DynamicResource Text.Fetch}"/>
            <TextBlock Classes="small italic" Margin="0,4,0,0" Text="{DynamicResource Text.CtrlClickTip}" Foreground="{DynamicResource Brush.FG2}"/>
          </StackPanel>
        </ToolTip.Tip>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Fetch}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Fetch}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Tapped="Pull" IsVisible="{Binding !IsBare}" IsEnabled="{Binding !IsBare}">
        <ToolTip.Tip>
          <StackPanel Orientation="Vertical">
            <TextBlock Text="{DynamicResource Text.Pull}"/>
            <TextBlock Classes="small italic" Margin="0,4,0,0" Text="{DynamicResource Text.CtrlClickTip}" Foreground="{DynamicResource Brush.FG2}"/>
          </StackPanel>
        </ToolTip.Tip>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Pull}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Pull}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Tapped="Push">
        <ToolTip.Tip>
          <StackPanel Orientation="Vertical">
            <TextBlock Text="{DynamicResource Text.Push}"/>
            <TextBlock Classes="small italic" Margin="0,4,0,0" Text="{DynamicResource Text.CtrlClickTip}" Foreground="{DynamicResource Brush.FG2}"/>
          </StackPanel>
        </ToolTip.Tip>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Push}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Push}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Tapped="StashAll" IsVisible="{Binding !IsBare}">
        <ToolTip.Tip>
          <StackPanel Orientation="Vertical">
            <TextBlock Text="{DynamicResource Text.Stash}"/>
            <TextBlock Classes="small italic" Margin="0,4,0,0" Text="{DynamicResource Text.CtrlClickTip}" Foreground="{DynamicResource Brush.FG2}"/>
          </StackPanel>
        </ToolTip.Tip>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Stashes.Add}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Stash}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Command="{Binding ApplyPatch}" IsVisible="{Binding !IsBare}" ToolTip.Tip="{DynamicResource Text.Apply}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Diff}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Apply}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Rectangle Width="1" Height="24"
                 Margin="12,0,0,0"
                 VerticalAlignment="Center"
                 Fill="{DynamicResource Brush.Border2}"/>

      <Button Classes="icon_button" Width="48" Margin="12,0,0,0" Command="{Binding CreateNewBranch}" ToolTip.Tip="{DynamicResource Text.Repository.NewBranch}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Branch.Add}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Branch}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Click="OpenGitFlowMenu" IsVisible="{Binding !IsBare}" ToolTip.Tip="{DynamicResource Text.GitFlow}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.GitFlow}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="Flow" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Click="OpenGitLFSMenu" IsVisible="{Binding !IsBare}" ToolTip.Tip="{DynamicResource Text.GitLFS}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.LFS}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="LFS" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="60" Margin="8,0,0,0" Click="StartBisect" IsVisible="{Binding !IsBare}" ToolTip.Tip="{DynamicResource Text.Bisect}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Bisect}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Bisect}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Click="OpenCustomActionMenu" ToolTip.Tip="{DynamicResource Text.Repository.CustomActions}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Data="{StaticResource Icons.Action}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Action}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>

      <Button Classes="icon_button" Width="48" Margin="8,0,0,0" Click="Cleanup" ToolTip.Tip="{DynamicResource Text.Repository.Clean}">
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
          <Path Width="16" Height="16" Margin="0,1,0,0" Data="{StaticResource Icons.Clean}" HorizontalAlignment="Center"/>
          <TextBlock FontSize="10" Text="{DynamicResource Text.Clean}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <StackPanel Grid.Column="2" Orientation="Horizontal">
      <Button Width="0" Height="0" Click="PushDirectlyByHotKey" IsVisible="False" HotKey="{OnPlatform Ctrl+Shift+Up, macOS=⌘+Shift+Up}"/>
      <Button Width="0" Height="0" Click="PullDirectlyByHotKey" IsVisible="False" IsEnabled="{Binding !IsBare}" HotKey="{OnPlatform Ctrl+Shift+Down, macOS=⌘+Shift+Down}"/>
      <Button Width="0" Height="0" Click="FetchDirectlyByHotKey" IsVisible="False" HotKey="{OnPlatform Ctrl+Down, macOS=⌘+Down}"/>
    </StackPanel>

    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
      <Path Width="13" Height="13" Fill="{DynamicResource Brush.FG1}" Data="{StaticResource Icons.Branch}"/>

      <ContentControl Margin="6,0,0,0">
        <ContentControl.Content>
          <Binding Path="CurrentBranch">
            <Binding.TargetNullValue>
              <TextBlock Text="--"/>
            </Binding.TargetNullValue>
          </Binding>
        </ContentControl.Content>

        <ContentControl.DataTemplates>
          <DataTemplate DataType="m:Branch">
            <Border Background="Transparent" ToolTip.Tip="{Binding FriendlyName}">
              <TextBlock Text="{Binding FriendlyName}" MaxWidth="250" TextTrimming="CharacterEllipsis"/>
            </Border>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

      <Button Classes="icon_button" Width="32" Click="NavigateToHead" ToolTip.Tip="{DynamicResource Text.Repository.NavigateToCurrentHead}">
        <Path Width="13" Height="13" Margin="0,2,0,0" Data="{StaticResource Icons.Target}" Fill="{DynamicResource Brush.FG1}"/>
      </Button>
    </StackPanel>
  </Grid>
</UserControl>
